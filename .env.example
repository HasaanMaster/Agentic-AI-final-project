# Copy this file to a new file named ".env" and fill in real values LATER.
# We'll do that together at the steps that need it - you don't need anything yet.
#
# IMPORTANT: never share your real .env or upload it to GitHub. It holds secrets.

# --- Google Cloud (we set this up together in Step 3) ---
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-project-id-here
GOOGLE_CLOUD_LOCATION=us-central1

# --- Web search (we set this up together in Step 4) ---
TAVILY_API_KEY=your-tavily-key-here
